# EvolveClaw SCOPE Server Configuration

# Server
EVOLVECLAW_HOST=127.0.0.1
EVOLVECLAW_PORT=5757

# LLM for SCOPE guideline synthesis
# Provider: "anthropic", "openai", or "litellm" (for 100+ providers)
EVOLVECLAW_SCOPE_PROVIDER=anthropic
EVOLVECLAW_SCOPE_MODEL=claude-sonnet-4-20250514

# API credentials (pick one set)
# Option A: Anthropic with custom base URL
ANTHROPIC_BASE_URL=https://your-proxy.example.com/claude
ANTHROPIC_AUTH_TOKEN=your-api-key-here

# Option B: OpenAI
# EVOLVECLAW_SCOPE_PROVIDER=openai
# EVOLVECLAW_SCOPE_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Option C: Any provider via LiteLLM (set provider to "litellm")
# EVOLVECLAW_SCOPE_PROVIDER=litellm
# EVOLVECLAW_SCOPE_MODEL=claude-sonnet-4-20250514
# EVOLVECLAW_SCOPE_API_KEY=your-key
# EVOLVECLAW_SCOPE_BASE_URL=https://your-endpoint.com
#
# Note: EVOLVECLAW_SCOPE_API_KEY / EVOLVECLAW_SCOPE_BASE_URL override
# provider-specific env vars but do NOT change which adapter is used.
# Set EVOLVECLAW_SCOPE_PROVIDER to control the adapter ("anthropic", "openai", or "litellm").

# SCOPE data directory (strategic rules persist here)
EVOLVECLAW_SCOPE_DATA=./scope_data

# SCOPE optimizer settings
EVOLVECLAW_SYNTHESIS_MODE=efficiency          # "efficiency" (fast) or "thoroughness" (comprehensive)
EVOLVECLAW_QUALITY_ANALYSIS=true              # Analyze successful steps too
EVOLVECLAW_QUALITY_FREQUENCY=3                # Analyze quality every N successful steps
EVOLVECLAW_ACCEPT_THRESHOLD=medium            # "all", "low", "medium", "high"
EVOLVECLAW_STRATEGIC_THRESHOLD=0.85           # Min confidence for strategic promotion
EVOLVECLAW_MAX_RULES_PER_TASK=20
EVOLVECLAW_MAX_STRATEGIC_PER_DOMAIN=10

# Feedback loop settings
EVOLVECLAW_FEEDBACK_NEGATIVE_RETIRE=3         # Retire a guideline after N negative ratings
EVOLVECLAW_FEEDBACK_POSITIVE_PROMOTE=5        # Reinforce retention after N positive ratings
